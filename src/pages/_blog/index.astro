---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import { t } from "@/i18n/translations";
import { getAllPosts } from "@/sanity/queries";

const locale = "nl";
const posts = await getAllPosts();
---

<BaseLayout
  title={t(locale, "blog.title") + " — DAR Hypotheken"}
  description={t(locale, "blog.description")}
  locale={locale}
  canonicalUrl="https://darhypotheken.nl/blog"
>
  <Header locale={locale} />

  <main class="bg-white py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6">
      <h1 class="text-3xl font-bold text-dar-slate md:text-5xl">
        {t(locale, "blog.title")}
      </h1>
      <p class="mt-4 text-lg text-dar-gray">
        {t(locale, "blog.description")}
      </p>

      {posts && posts.length > 0 ? (
        <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post: any) => (
            <BlogCard
              title={post.title}
              excerpt={post.excerpt}
              slug={post.slug?.current || post.slug}
              mainImage={post.mainImage}
              publishedAt={post.publishedAt}
              categories={post.categories}
              locale={locale}
            />
          ))}
        </div>
      ) : (
        <p class="mt-12 text-dar-gray">{t(locale, "blog.noPosts")}</p>
      )}
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>
