---
import { t } from "@/i18n/translations";
import { NAV_ITEMS } from "@/lib/constants";
import HeaderIsland from "./HeaderIsland";
import LanguageSwitcher from "./LanguageSwitcher";

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const homeHref = locale === "nl" ? "/" : "/en";
const aanmeldenHref = locale === "nl" ? "/aanmelden" : "/en/aanmelden";
const aanmeldenText = t(locale, "nav.anmelding");

const navItems = NAV_ITEMS.map((item) => ({
  href: item.href,
  label: t(locale, `nav.${item.key}`),
}));
---

<header id="site-header" class="sticky top-0 z-50 bg-dar-navy transition-all duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 transition-all duration-300" id="header-inner">
    <a href={homeHref} class="shrink-0">
      <img
        src="/images/dar-logo.svg"
        alt="DAR Hypotheken"
        width="100"
        height="40"
        id="header-logo"
        class="transition-all duration-300"
      />
    </a>

    <nav class="absolute left-1/2 hidden -translate-x-1/2 items-center gap-8 nav:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-dar-cream transition-opacity hover:opacity-80"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-4 nav:flex">
      <LanguageSwitcher client:load locale={locale} className="text-dar-cream" />
      <a
        href={aanmeldenHref}
        class="shrink-0 rounded-full bg-dar-green px-5 py-2 text-sm font-semibold text-white transition-opacity hover:opacity-90"
      >
        {aanmeldenText}
      </a>
    </div>

    <HeaderIsland
      client:load
      items={navItems}
      aanmeldenHref={aanmeldenHref}
      aanmeldenText={aanmeldenText}
      locale={locale}
    />
  </div>
</header>

<script is:inline>
  (function() {
    var header = document.getElementById("site-header");
    var inner = document.getElementById("header-inner");
    var logo = document.getElementById("header-logo");
    var scrolled = false;

    function onScroll() {
      var isScrolled = window.scrollY > 20;
      if (isScrolled === scrolled) return;
      scrolled = isScrolled;
      if (isScrolled) {
        inner.style.paddingTop = "0.5rem";
        inner.style.paddingBottom = "0.5rem";
        logo.style.width = "70px";
        logo.style.height = "28px";
      } else {
        inner.style.paddingTop = "";
        inner.style.paddingBottom = "";
        logo.style.width = "";
        logo.style.height = "";
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>
