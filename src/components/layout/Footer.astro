---
import { t, tWithParams } from "@/i18n/translations";
import LanguageSwitcher from "./LanguageSwitcher";

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const privacyHref = locale === "nl" ? "/privacy" : "/en/privacy";
const blogHref = locale === "nl" ? "/blog" : "/en/blog";
const currentYear = new Date().getFullYear();
---

<footer class="bg-dar-navy">
  <div class="mx-auto max-w-7xl px-6 py-12 md:py-16">
    <div class="grid gap-8 md:grid-cols-4">
      <!-- Logo & tagline -->
      <div>
        <img
          src="/images/dar-logo.svg"
          alt="DAR Hypotheken"
          width="80"
          height="32"
        />
        <p class="mt-4 text-sm text-dar-cream/70">
          {t(locale, "footer.tagline")}
        </p>
        <a
          href="https://maps.google.com/?q=Mercuriusweg+26,+2516+AW+Den+Haag"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 block text-sm leading-snug text-dar-cream/50 underline hover:text-dar-cream/70"
        >
          Mercuriusweg 26<br />
          2516 AW, The Hague (NL)
        </a>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="mb-3 font-semibold text-dar-cream">
          {t(locale, "footer.navigation")}
        </h4>
        <ul class="space-y-2 text-sm text-dar-cream/70">
          <li>
            <a href="#about" class="hover:text-dar-cream">
              {t(locale, "footer.aboutUs")}
            </a>
          </li>
          <li>
            <a href="#process" class="hover:text-dar-cream">
              {t(locale, "footer.howItWorks")}
            </a>
          </li>
          <li>
            <a href="#team" class="hover:text-dar-cream">
              {t(locale, "footer.team")}
            </a>
          </li>
          <li>
            <a href="#contact" class="hover:text-dar-cream">
              {t(locale, "footer.contact")}
            </a>
          </li>
          {/* Blog hidden — restore by uncommenting this block
          <li>
            <a href={blogHref} class="hover:text-dar-cream">
              Blog
            </a>
          </li>
          */}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="mb-3 font-semibold text-dar-cream">
          {t(locale, "footer.legal")}
        </h4>
        <ul class="space-y-2 text-sm text-dar-cream/70">
          <li>
            <a href={privacyHref} class="hover:text-dar-cream">
              {t(locale, "footer.privacy")}
            </a>
          </li>
          <li>
            <button
              type="button"
              data-open-cookie-settings
              class="text-left hover:text-dar-cream"
            >
              {t(locale, "footer.cookieSettings")}
            </button>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="mb-3 font-semibold text-dar-cream">
          {t(locale, "footer.contactHeading")}
        </h4>
        <p class="text-sm text-dar-cream/70">info@darhypotheken.nl</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex items-center justify-between border-t border-dar-cream/20 pt-6 text-sm text-dar-cream/50">
      <span>
        {tWithParams(locale, "footer.copyright", { year: currentYear })}
      </span>
      <LanguageSwitcher client:load locale={locale} className="text-dar-cream/70" />
    </div>
  </div>
</footer>

<script is:inline>
  document.addEventListener("click", function (e) {
    var target = e.target;
    if (!target) return;
    var btn = target.closest
      ? target.closest("[data-open-cookie-settings]")
      : null;
    if (btn) {
      e.preventDefault();
      window.dispatchEvent(new CustomEvent("dar:open-cookie-settings"));
    }
  });
</script>
