---
import { urlFor } from "@/sanity/image";

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  mainImage?: { asset: { _ref: string }; alt?: string };
  publishedAt?: string;
  categories?: string[];
  locale: string;
}

const { title, excerpt, slug, mainImage, publishedAt, categories, locale } = Astro.props;
const href = locale === "nl" ? `/blog/${slug}` : `/en/blog/${slug}`;
const dateLocale = locale === "nl" ? "nl-NL" : "en-US";
---

<a href={href} class="group block">
  <article class="overflow-hidden rounded-2xl bg-white shadow-md transition-shadow hover:shadow-lg">
    {mainImage?.asset && (
      <div class="relative h-48 w-full overflow-hidden">
        <img
          src={urlFor(mainImage).width(600).height(340).fit("crop").url()}
          alt={mainImage.alt || title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
          decoding="async"
          width="600"
          height="340"
        />
      </div>
    )}
    <div class="p-6">
      {categories && categories.length > 0 && (
        <div class="mb-2 flex flex-wrap gap-2">
          {categories.map((cat) => (
            <span class="rounded-full bg-dar-blue/10 px-3 py-0.5 text-xs font-medium text-dar-blue">
              {cat}
            </span>
          ))}
        </div>
      )}
      <h3 class="text-lg font-semibold text-dar-slate group-hover:text-dar-blue">
        {title}
      </h3>
      {excerpt && (
        <p class="mt-2 line-clamp-2 text-sm text-dar-gray">{excerpt}</p>
      )}
      {publishedAt && (
        <time class="mt-3 block text-xs text-dar-gray/60">
          {new Date(publishedAt).toLocaleDateString(dateLocale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
      )}
    </div>
  </article>
</a>
